# ─── LLM Provider Keys (priority: Gemini > OpenAI > Groq) ────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...

# ─── AWS Credentials (read-only IAM role required) ───────────────────────────
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=us-east-1

# ─── Storage Paths (override for Docker volume mounts) ───────────────────────
# EVIDENCE_VAULT_PATH=/mnt/evidence_vault
# SESSIONS_PATH=/mnt/data/audit_sessions.json

# ─── Evidence Vault Encryption (optional, strongly recommended in production) ─
# Generate a key: python -c "import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
# VAULT_ENCRYPTION_KEY=<base64-encoded-32-byte-key>

# ─── Runtime Flags ────────────────────────────────────────────────────────────
# DEMO_MODE=0        # Set to 1 for local demo only — bypasses LLM crews
# ENVIRONMENT=local  # Set to production/staging to enable DEMO_MODE guard
